<?xml version="1.0"?>
<ruleset name="Simple Spam Shield">
	<description>WordPress coding standards for Simple Spam Shield.</description>

	<file>.</file>
	<exclude-pattern>vendor/*</exclude-pattern>
	<exclude-pattern>node_modules/*</exclude-pattern>

	<arg name="extensions" value="php"/>
	<arg name="colors"/>
	<arg value="sp"/>

	<rule ref="WordPress">
		<exclude name="WordPress.Files.FileName.InvalidClassFileName"/>

		<!--
			Style exclusions only. Every WordPress.Security.* sniff stays
			enabled. The plugin deliberately targets PHP 8.1+ and uses modern
			syntax; the excluded sniffs enforce older WordPress-core formatting
			that conflicts with that intentional style.
		-->
		<!-- Short array syntax [] is used throughout by design. -->
		<exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
		<!-- Inline closures / compact multi-line calls (autoloader, hooks). -->
		<exclude name="PEAR.Functions.FunctionCallSignature"/>

		<!--
			Documentation strictness. Each file has a file-level docblock and
			each method a summary docblock; with PHP 8.1 typed signatures the
			per-parameter @param tags and separate class docblocks are
			redundant. These are not security sniffs.
		-->
		<exclude name="Squiz.Commenting.ClassComment.Missing"/>
		<exclude name="Squiz.Commenting.FunctionComment.Missing"/>
		<exclude name="Squiz.Commenting.FunctionComment.MissingParamTag"/>
		<exclude name="Squiz.Commenting.VariableComment.Missing"/>
		<exclude name="Generic.Commenting.DocComment.MissingShort"/>

		<!-- $default and $class match WordPress-core parameter conventions. -->
		<exclude name="Universal.NamingConventions.NoReservedKeywordParameterNames"/>

		<!--
			Every database call in this plugin targets its own custom log
			table (wp_sss_spam_logs) with prepared, column-whitelisted
			queries. Object-caching a spam-audit log is inappropriate, and a
			dedicated table is the documented pattern for this data. The
			injection-focused WordPress.DB.PreparedSQL* sniffs stay enabled.
		-->
		<exclude name="WordPress.DB.DirectDatabaseQuery"/>
	</rule>

	<config name="minimum_wp_version" value="6.2"/>
	<config name="testVersion" value="8.1-"/>
</ruleset>
