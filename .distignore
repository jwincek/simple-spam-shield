# Files and directories excluded from the distributed plugin package.
# Everything here is development tooling or source control; none of it is
# needed at runtime. The shipped zip is runtime-only.

/.git
/.github
/.gitignore
/.distignore
/.wordpress-org
/node_modules
/vendor
/composer.json
/composer.lock
/phpcs.xml.dist
/.phpcs-cache
/phpunit.xml.dist
/.phpunit.cache
/.phpunit.result.cache
/tests
/README.md
/CONTRIBUTING.md
/CHANGELOG.md
.DS_Store
